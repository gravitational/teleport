package resources

import (
	"context"
	"fmt"
	"io"
{{- if .HasTimestampColumn}}
	"time"
{{- end}}

	"github.com/gravitational/trace"
{{- if .HasTimestampColumn}}
	"google.golang.org/protobuf/types/known/timestamppb"
{{- end}}

	{{.PkgAlias}} "{{.ImportPath}}"
	"{{.Module}}/api/types"
{{- if .Ops.List}}
	"{{.Module}}/api/utils/clientutils"
{{- end}}
	"{{.Module}}/lib/asciitable"
	"{{.Module}}/lib/auth/authclient"
