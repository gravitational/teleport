# Terraform config for creating an Access List.

terraform {
  required_providers {
    teleport = {
      source  = "terraform.releases.teleport.dev/gravitational/teleport"
      version = "~> 19.0"
    }
  }
}

provider "teleport" {
  addr = "proxy.example.com:3080"
}

resource "teleport_access_list" "acl-plain-access-list" {
  header = {
    kind    = "access_list"
    version = "v1"
    metadata = {
      name = "plain-access-list"
    }
  }

  spec = {
    description = "some description"
    owners = [{
      description     = "owner description"
      membership_kind = "1"
      name            = "llama"
    }]
    grants = {
      roles = ["access", "editor"]
      traits = [{
        key    = "logins"
        values = ["root"]
      }]
    }
    title = "Plain Access List"
    type  = "static"
  }
}

resource "teleport_access_list_member" "acl-member-llama_836e2c96" {
  depends_on = [teleport_access_list.acl-plain-access-list]

  header = {
    kind    = "access_list_member"
    version = "v1"
    metadata = {
      name = "llama"
    }
  }

  spec = {
    access_list     = "plain-access-list"
    name            = "llama"
    membership_kind = "1"
  }
}

resource "teleport_access_list_member" "acl-member-alpaca_fe256c33" {
  depends_on = [teleport_access_list.acl-plain-access-list]

  header = {
    kind    = "access_list_member"
    version = "v1"
    metadata = {
      name = "alpaca"
    }
  }

  spec = {
    access_list     = "plain-access-list"
    name            = "alpaca"
    reason          = "some reason"
    membership_kind = "1"
  }
}
