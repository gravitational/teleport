resource "teleport_role" "example-role" {
  version = "v8"

  metadata = {
    name = "example-role"
  }

  spec = {
    allow = {
      rules = [{
        verbs = ["verb1"]
        where = "where1"
        }, {
        verbs = ["verb2"]
        where = "where2"
      }]
      kubernetes_groups = ["system:masters"]
      request = {
        claims_to_roles = [{
          claim = "some claim"
          }, {
          claim = "some claim 2"
        }]
        suggested_reviewers = ["reviewer1", "reviewer2"]
      }
    }
    deny = {
      rules = [{
        resources = ["resource1"]
        verbs     = ["verb1"]
      }]
    }
  }
}
