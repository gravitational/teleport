version: v3
teleport:
  nodename: linux-desktop-1
  data_dir: /var/lib/teleport
  log:
    output: stderr
    severity: DEBUG
  proxy_server: 192.168.6.34:3080
  auth_token: REPLACE_WITH_TOKEN
  ca_pin: "REPLACE_WITH_CA_PIN"

auth_service:
  enabled: false
proxy_service:
  enabled: false
ssh_service:
  enabled: false

linux_desktop_service:
  enabled: yes
  labels:
    env: staging
