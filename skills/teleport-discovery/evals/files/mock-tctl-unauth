#!/usr/bin/env python3
"""Mock tctl that simulates an unauthenticated state."""
import sys

args = sys.argv[1:]
if not args:
    sys.exit(1)

cmd = args[0]

if cmd == "status":
    print("ERROR: Not logged in. Run: tsh login --proxy=<proxy-addr>", file=sys.stderr)
    sys.exit(1)
elif cmd == "version":
    print("Teleport v18.8.0 git:abc123 go1.22.0")
else:
    print(f"ERROR: unknown command: {cmd}", file=sys.stderr)
    sys.exit(1)
