#!/usr/bin/env python3
"""Mock tsh binary simulating an unauthenticated (not logged in) state."""
import sys

args = sys.argv[1:]
cmd = args[0] if args else ""

if cmd == "status":
    print("ERROR: Not logged in. Run: tsh login --proxy=<proxy-addr>", file=sys.stderr)
    sys.exit(1)
else:
    print(f"ERROR: unknown command: {cmd}", file=sys.stderr)
    sys.exit(1)
